# ============================================================
#  ChatBot Juridique RAG — Variables d'environnement Backend
#  Copier ce fichier en .env et remplir les vraies valeurs
#  NE JAMAIS committer le fichier .env sur GitHub !
# ============================================================

# ── Base de données (Supabase PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[MOT_DE_PASSE]@db.tysszzvnoyxrgrrxvmnj.supabase.co:5432/postgres

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_ISSUER=https://[votre-instance].clerk.accounts.dev

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── OpenAI (pour extraction PDF Vision) ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LaTeXLite ─────────────────────────────────────────────────────────────────
LATEXLITE_API_KEY=

# ── RAG Pipeline (ChromaDB) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION_NAME=legal_docs_arabic
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# ── CORS (URLs autorisées) ────────────────────────────────────────────────────
# En production, remplacer par l'URL Vercel exacte :
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://votre-app.vercel.app"]

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

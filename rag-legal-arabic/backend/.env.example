# ===================================================
# RAG Bot - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ===================================================

# --- OpenAI (GPT-4o Vision - OBLIGATOIRE) ---
OPENAI_API_KEY=sk-...votre_clé_ici...

# --- Ollama (LLM local - Gratuit) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=legal_docs_arabic

# --- BGE-M3 Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- Extraction Intelligente (Smart Routing) ---
# true  = auto-détection (PyMuPDF gratuit si textuel, GPT-4o si scanné)
# false = toujours GPT-4o Vision (plus précis mais payant sur tous les PDFs)
AUTO_DETECT_EXTRACTION=true
# Seuil de caractères/page pour considérer un PDF comme scanné (< seuil = scanné)
SCAN_DETECTION_THRESHOLD=50

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
